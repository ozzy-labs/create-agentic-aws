{
  "name": "create-agentic-aws",
  "version": "0.2.0",
  "description": "CLI tool to generate AI-agent-native AWS projects — supports Amazon Q, Claude Code, Copilot, and more",
  "type": "module",
  "bin": {
    "create-agentic-aws": "./dist/index.mjs"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "prepare": "lefthook install || true",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "lint:all": "pnpm run lint && pnpm run typecheck && pnpm run lint:md && pnpm run lint:yaml && pnpm run lint:shell && pnpm run lint:toml && pnpm run lint:secrets",
    "lint:md": "markdownlint-cli2 '**/*.md' '#**/node_modules' '#**/templates'",
    "lint:yaml": "yamllint -c .yamllint.yaml .",
    "lint:shell": "if ls scripts/*.sh 1>/dev/null 2>&1; then shellcheck scripts/*.sh && shfmt -d scripts/; else echo 'No shell scripts found'; fi",
    "lint:toml": "taplo format --check ./*.toml",
    "lint:secrets": "gitleaks detect --no-banner",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "vitest run tests/smoke.test.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.12.1",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ozzy-labs/create-agentic-aws.git"
  },
  "keywords": [
    "create",
    "scaffold",
    "template",
    "ai",
    "agent",
    "aws",
    "cdk",
    "terraform",
    "claude",
    "amazon-q",
    "copilot"
  ],
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "deepmerge-ts": "^7.0.0",
    "picocolors": "^1.1.0",
    "smol-toml": "^1.4.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "tsdown": "^0.21.10",
    "typescript": "^5.8.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "overrides": {
      "defu": "^6.1.5",
      "postcss": "^8.5.10",
      "vite": "^8.0.10"
    }
  }
}
